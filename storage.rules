rules_version = '2';

// Terapkan aturan ke bucket spesifik proyek Anda.
// Ini adalah perbaikan krusial untuk memastikan aturan keamanan diterapkan dengan benar.
service firebase.storage {
  match /b/nextcast-554f2.appspot.com/o {
    
    // Aturan untuk folder 'images'
    // Folder ini akan berisi semua aset media yang diunggah seperti banner email.
    match /images/{allPaths=**} {
      // Siapa saja diizinkan untuk membaca (melihat) gambar.
      // Ini penting agar gambar dapat ditampilkan di email klien yang tidak login.
      allow read: if true;

      // Hanya pengguna yang sudah terautentikasi (login) yang diizinkan untuk
      // membuat, memperbarui, atau menghapus file (mengunggah/mengelola aset).
      allow write: if request.auth != null;
    }
    
    // Aturan default untuk semua path lain (opsional, tapi praktik yang baik)
    // Blokir semua akses ke path lain secara default.
    match /{allPaths=**} {
        allow read, write: if false;
    }
  }
}
