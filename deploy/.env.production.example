# SalesCore Production Environment Variables
# Copy this to /opt/salescore/apps/backend/.env on the VPS

# ─── Postgres (running on same VPS) ──────────────────
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=salescore
PGPASSWORD=salescore_pass
PGDATABASE=salescore
PG_POOL_SIZE=15

# ─── Redis (optional, for task caching) ──────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TTL_SECONDS=30

# ─── Cloudflare R2 ───────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=salescore-ocr

# ─── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=sk-your-key
OPENAI_OCR_MODEL=gpt-4.1
OPENAI_PREFLIGHT_MODEL=gpt-4.1-mini
OPENAI_BOX_SCAN_MODEL=gpt-4.1
OPENAI_IDENTITY_REVIEW_MODEL=gpt-5.5
OPENAI_VERIFIER_MODEL=gpt-4.1

# ─── Ollama (optional) ───────────────────────────────
OLLAMA_API_KEY=
OLLAMA_OCR_MODEL=gemma3:27b
OLLAMA_ENDPOINT=https://ollama.com/v1/chat/completions

# ─── Session ─────────────────────────────────────────
SESSION_SECRET=replace-with-random-64-char-string

# ─── Firebase (still needed for legacy Server Actions) ──
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_service_account

# ─── Frontend public vars (also needed by backend OCR flows) ──
NEXT_PUBLIC_AUTH_MODE=local
NEXT_PUBLIC_OCR_FOCUS_MODE=true
